# App Base URL (used for OAuth callback generation in local/Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Optional: override callback url, defaults to {BASE_URL}/api/auth/github/callback
GITHUB_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/github/callback

# GitHub admin allowlist (comma separated)
GITHUB_ADMIN_USERS=yokeay,another-admin
# Optional: override scopes (comma separated)
GITHUB_OAUTH_SCOPES=read:user

# Optional: explicit base url for OAuth in serverless/preview env
GITHUB_OAUTH_BASE_URL=https://your-vercel-domain.vercel.app

# Optional: password required for /docs. If omitted, falls back to config/app.config.json default.
DOCS_ACCESS_PASSWORD=fntp@polofox.com

# Session signing secret
AUTH_SESSION_SECRET=replace_with_a_long_random_secret

# Data layer examples (PostgreSQL + Redis)
DATABASE_URL=postgresql://username:password@localhost:5432/ddmusic
REDIS_URL=redis://localhost:6379
# Optional: Upstash Redis (when REDIS_URL is not provided)
UPSTASH_REDIS_URL=rediss://default:password@your-upstash-endpoint:6379
REDIS_KEY_PREFIX=bendywork_ddmusic_nextjs_
REDIS_CACHE_TTL_SECONDS=60

# Optional: override repository from env
GITHUB_REPO=bendywork/bendy-music-nextjs
# Docs sync to repository (README + API doc)
DOCS_REPO_SYNC_ENABLED=true
DOCS_REPO_SYNC_BRANCH=main
DOCS_REPO_TOKEN_ENV=GITHUB_REPO_TOKEN
DOCS_REPO_README_PATH=README.md
DOCS_REPO_API_PATH=doc/doc-prop.json
DOCS_REPO_COMMIT_PREFIX=docs
DOCS_REPO_COMMIT_AUTHOR=ddmusic-bot
DOCS_REPO_COMMIT_EMAIL=bot@ddmusic.local
GITHUB_REPO_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

S3_ENDPOINT=https://s3.example.com
S3_BUCKET=ddmusic-assets
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Disaster recovery switches (disabled by default)
ENABLE_DR_BACKUP=false
DR_BACKUP_CRON=0 3 * * *
